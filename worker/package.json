{
  "name": "purerss-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format cjs --out-dir dist --no-splitting",
    "start": "node dist/server.js"
  },
  "overrides": {
    "esbuild": ">=0.28.1"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.10.0",
    "hono": "^4.7.0",
    "jose": "^6.2.3",
    "node-html-parser": "^6.1.13",
    "nodemailer": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3"
  }
}
